
<% layout("/layouts/boilerplate") %>
<style>
    #filters{
        display: flex;
        flex-wrap: wrap;
        align-items: center;
    }

    .filters{
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
        opacity: 0.7;
        align-items: center;
        margin-left: 0.4rem;


    }

    .filters:hover {
        opacity: 1;
        cursor: pointer;

    }

    .filters p{
        font-size: 0.8rem;
    }

    .tax-info{
        display: none;
    }
    .tax-toggle {
        border: 2px solid black;
        border-radius: 1rem;
        height: 3rem;
        padding: 0.7rem;
        margin-left: auto;

}
.rating {
    margin-top: 6px;
    font-size: 0.9rem;
    color: #333;
    display: flex;
    align-items: center;
    gap: 5px;
}

.rating i {
    color: #ff385c; /* Airbnb red */
    font-size: 0.9rem;
}
.rating-text {
    margin-left: 5px;
    color: #333;
    font-weight: 500;
}

</style>
<div id="filters">
    <div class="filters">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending </p>
    </div>

    <div class="filters">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
    </div>

    <div class="filters">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>iconic Cities</p>
    </div>

    <div class="filters">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
    </div>

    <div class="filters">
        <div><i class="fa-brands fa-fort-awesome"></i></div>
        <p>Forts</p>
    </div>

    <div class="filters">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing Pools</p>
    </div>

    <div class="filters">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
    </div>

    <div class="filters">
        <div><i class="fa-solid fa-seedling"></i></div>
        <p>Farm Stay</p>
    </div>

    <div class="filters">
        <div><i class="fa-solid fa-snowflake"></i></div>
        <p>Arctic</p>
    </div>

    <div class="filters">
        <div><i class="fa-solid fa-igloo"></i></div>
        <p>Domes</p>
    </div>

    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
        </div>
    </div>


</div>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings){ %>

    <div class="card listing-card col">
            <div class="card h-100 listing-card position-relative">

                <a href="/listings/<%= listing._id %>" class="listing-link">


                    <img 
                        src="<%= listing.image.url %>"
                        class="card-img-top" 
                        alt="listing_image" 
                        style="height: 20rem; object-fit: cover;"
                    />
                    <div class="rating">
                        <% for(let i = 1; i <= 5; i++) { %>
                            <% if(i <= listing.rating) { %>
                                <i class="fa-solid fa-star"></i>
                            <% } else { %>
                                <i class="fa-regular fa-star"></i>
                            <% } %>
                        <% } %>
                        <span class="rating-text">
                                (<%= listing.rating ? listing.rating.toFixed(1) : "New" %>)
                        </span>
                    </div>

                    
            </a>

            <form action="/listings/<%= listing._id %>/like" method="POST">

                <button class="like-icon">

                    <i class="
                    <%= currUser && currUser.wishlist.includes(listing._id)
                    ? 'fa-solid fa-heart liked'
                    : 'fa-regular fa-heart' %>
                    "></i>

                </button>

            </form>

            <div class="card-body">
                <a href="/listings/<%= listing._id %>" class="listing-link"></a>
                    <p class="card-text">
                        <b><%= listing.title %></b><br>
                        &#8377; <%= listing.price.toLocaleString("en-IN") %> /night
                        <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
                    </p>

                </a>
                </div>

            </div>

        </a>
    </div>

    <% } %>
</div>
<script>

    // tax toggle
    let taxSwitch = document.getElementById("switchCheckDefault");

    taxSwitch.addEventListener('click', () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        console.log(taxInfo);
        for(let info of taxInfo){
            if(taxSwitch.checked){
                info.style.display = "inline";
            }else{
                info.style.display = "none"; 
            }
        }
        // // console.log("clicked");
    });
// info.style.display != "inline
    //     console.log(taxInfo);

    //     for (let info of taxInfo) {
    //         if(taxSwitch.checked){
    //             info.style.display = "inline";
    //         }else{
    //             info.style.display = "none";
    //         }
            
    //     }
    // });

    // Like button
    let hearts = document.querySelectorAll(".like-icon i");

    hearts.forEach((heart) => {

        heart.addEventListener("click", (e) => {

            e.preventDefault();
            e.stopPropagation();

            heart.classList.toggle("fa-regular");
            heart.classList.toggle("fa-solid");

            heart.classList.toggle("liked");

        });

    });

</script>